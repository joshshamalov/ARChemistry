<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base theme for Compose activities -->
    <style name="Theme.ARChemistry" parent="Theme.AppCompat.NoActionBar">
        <item name="android:statusBarColor">@color/ar_dark_background</item>
        <item name="android:navigationBarColor">@color/ar_dark_background</item>
        <item name="android:windowBackground">@color/ar_dark_background</item>
    </style>

    <!-- Theme for the Crop Activity -->
    <style name="Theme.ARChemistry.Crop" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/ar_primary_blue</item>
        <item name="colorPrimaryDark">@color/ar_primary_blue</item>
        <item name="colorAccent">@color/ar_primary_blue</item>
        <item name="android:windowBackground">@color/ar_dark_background</item>
        <item name="android:statusBarColor">@color/ar_dark_background</item>
        <item name="android:navigationBarColor">@color/ar_dark_background</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="actionMenuTextColor">@color/ar_text_primary</item>
    </style>

    <!-- Edge-to-Edge Theme for the Custom Crop Activity -->
    <style name="Theme.ARChemistry.EdgeToEdge" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/ar_primary_blue</item>
        <item name="colorPrimaryDark">@color/ar_primary_blue</item>
        <item name="colorAccent">@color/ar_primary_blue</item>
        <item name="android:windowBackground">@color/ar_dark_background</item>
        <item name="android:statusBarColor">@color/ar_primary_blue</item>
        <item name="android:navigationBarColor">@color/ar_dark_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:windowFullscreen">false</item>
    </style>
</resources>